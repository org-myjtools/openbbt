{
  "name": "openbbt",
  "displayName": "OpenBBT",
  "description": "Language support for OpenBBT feature files",
  "version": "1.0.0-alpha1",
  "publisher": "myjtools.org",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Testing"],
  "activationEvents": [
    "workspaceContains:openbbt.yaml"
  ],
  "icon": "./resources/openbbt-icon.svg",
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "feature",
        "aliases": ["Gherkin", "Feature"],
        "extensions": [".feature"],
        "mimetypes": ["text/x-feature"],
        "configuration": "./language-configuration.json"
      },
      {
        "id": "yaml",
        "filenames": ["openbbt.yaml"]
      }
    ],
    "commands": [
      {
        "command": "openbbt.installPlugins",
        "title": "OpenBBT: Install plugins",
        "icon": "$(cloud-download)"
      },
      {
        "command": "openbbt.testPlan.refresh",
        "title": "OpenBBT: Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "openbbt.openSource",
        "title": "OpenBBT: Open Source Location"
      },
      {
        "command": "openbbt.executions.run",
        "title": "OpenBBT: Run",
        "icon": "$(run-all)"
      },
      {
        "command": "openbbt.executions.rerun",
        "title": "OpenBBT: Re-run",
        "icon": "$(run-all)"
      },
      {
        "command": "openbbt.executions.deleteExecution",
        "title": "OpenBBT: Delete Execution",
        "icon": "$(trash)"
      },
      {
        "command": "openbbt.executions.deletePlan",
        "title": "OpenBBT: Delete Plan",
        "icon": "$(trash)"
      },
      {
        "command": "openbbt.executions.pruneEmpty",
        "title": "OpenBBT: Delete Plans Without Executions",
        "icon": "$(clear-all)"
      },
      {
        "command": "openbbt.contributors.refresh",
        "title": "OpenBBT: Refresh Contributors",
        "icon": "$(refresh)"
      },
      {
        "command": "openbbt.showLogs",
        "title": "OpenBBT: Show Logs",
        "icon": "$(output)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "openbbt",
          "title": "OpenBBT",
          "icon": "./resources/openbbt-activity.svg"
        }
      ]
    },
    "views": {
      "openbbt": [
        {
          "id": "openbbt.testPlan",
          "name": "Test Plan",
          "icon": "$(list-tree)"
        },
        {
          "id": "openbbt.executions",
          "name": "Executions",
          "icon": "$(run-all)"
        },
        {
          "id": "openbbt.contributors",
          "name": "Contributors",
          "icon": "$(extensions)"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "openbbt.executions.pruneEmpty",
          "when": "view == openbbt.executions",
          "group": "navigation"
        },
        {
          "command": "openbbt.executions.run",
          "when": "view == openbbt.testPlan",
          "group": "navigation"
        },
        {
          "command": "openbbt.testPlan.refresh",
          "when": "view == openbbt.testPlan",
          "group": "navigation"
        },
        {
          "command": "openbbt.contributors.refresh",
          "when": "view == openbbt.contributors",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "openbbt.executions.rerun",
          "when": "view == openbbt.executions && viewItem == execution",
          "group": "inline@1"
        },
        {
          "command": "openbbt.executions.deleteExecution",
          "when": "view == openbbt.executions && viewItem == execution",
          "group": "inline@2"
        },
        {
          "command": "openbbt.executions.deletePlan",
          "when": "view == openbbt.executions && viewItem == plan",
          "group": "inline"
        }
      ]
    },
    "grammars": [
      {
        "language": "feature",
        "scopeName": "text.gherkin.feature",
        "path": "./syntaxes/feature.tmLanguage.json",
        "embeddedLanguages": {
          "meta.embedded.block.json": "json",
          "meta.embedded.block.xml": "xml",
          "meta.embedded.block.html": "html",
          "meta.embedded.block.javascript": "javascript",
          "meta.embedded.block.typescript": "typescript",
          "meta.embedded.block.sql": "sql",
          "meta.embedded.block.yaml": "yaml",
          "meta.embedded.block.python": "python"
        }
      }
    ],
    "configuration": {
      "title": "OpenBBT",
      "properties": {
        "openbbt.executablePath": {
          "type": "string",
          "default": "openbbt",
          "description": "Path to the openbbt CLI executable. Defaults to 'openbbt' (must be on PATH)."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "vscode:prepublish": "npm run compile"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.3.0"
  }
}
