{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Gherkin",
  "scopeName": "text.gherkin.feature",
  "patterns": [
    { "include": "#comment" },
    { "include": "#tag" },
    { "include": "#feature" },
    { "include": "#background" },
    { "include": "#scenario" },
    { "include": "#scenarioOutline" },
    { "include": "#examples" },
    { "include": "#step" },
    { "include": "#docstringJson" },
    { "include": "#docstringXml" },
    { "include": "#docstringHtml" },
    { "include": "#docstringJs" },
    { "include": "#docstringTs" },
    { "include": "#docstringSql" },
    { "include": "#docstringYaml" },
    { "include": "#docstringPython" },
    { "include": "#docstring" },
    { "include": "#table" }
  ],
  "repository": {
    "comment": {
      "match": "^\\s*#.*$",
      "name": "comment.line.number-sign.feature"
    },
    "tag": {
      "match": "@[\\w-]+",
      "name": "entity.name.tag.feature"
    },
    "feature": {
      "match": "^(Feature|Funcionalidad|Característica)(:)(.*)",
      "captures": {
        "1": { "name": "keyword.control.feature" },
        "2": { "name": "punctuation.definition.feature" },
        "3": { "name": "entity.name.section.feature" }
      }
    },
    "background": {
      "match": "^\\s*(Background|Antecedentes|Fondo)(:)(.*)",
      "captures": {
        "1": { "name": "keyword.control.background.feature" },
        "2": { "name": "punctuation.definition.feature" },
        "3": { "name": "string.unquoted.feature" }
      }
    },
    "scenario": {
      "match": "^\\s*(Scenario|Example|Escenario|Ejemplo)(:)(.*)",
      "captures": {
        "1": { "name": "keyword.control.scenario.feature" },
        "2": { "name": "punctuation.definition.feature" },
        "3": { "name": "entity.name.section.scenario.feature" }
      }
    },
    "scenarioOutline": {
      "match": "^\\s*(Scenario Outline|Scenario Template|Esquema del escenario|Plantilla del escenario)(:)(.*)",
      "captures": {
        "1": { "name": "keyword.control.scenario.outline.feature" },
        "2": { "name": "punctuation.definition.feature" },
        "3": { "name": "entity.name.section.scenario.feature" }
      }
    },
    "examples": {
      "match": "^\\s*(Examples|Scenarios|Ejemplos)(:)(.*)",
      "captures": {
        "1": { "name": "keyword.control.examples.feature" },
        "2": { "name": "punctuation.definition.feature" },
        "3": { "name": "string.unquoted.feature" }
      }
    },
    "step": {
      "match": "^\\s*(Given that|Given|When|Then|And|But|Dado que|Dado|Dada|Dados|Dadas|Cuando|Entonces|Y|E|Pero)(?=\\s|$)(.*)",
      "captures": {
        "1": { "name": "keyword.control.step.feature" },
        "2": {
          "patterns": [
            { "include": "#stepPlaceholder" },
            { "include": "#stepString" },
            { "include": "#stepNumber" }
          ]
        }
      }
    },
    "stepPlaceholder": {
      "match": "<[^>]+>",
      "name": "variable.other.placeholder.feature"
    },
    "stepString": {
      "match": "\"[^\"]*\"",
      "name": "string.quoted.double.feature"
    },
    "stepNumber": {
      "match": "\\b\\d+(\\.\\d+)?\\b",
      "name": "constant.numeric.feature"
    },
    "docstringJson": {
      "begin": "^(\\s*)(\"\"\"|```)(json)\\s*$",
      "end": "^\\1(\"\"\"|```)",
      "beginCaptures": {
        "2": { "name": "punctuation.definition.string.feature" },
        "3": { "name": "storage.type.docstring.feature" }
      },
      "endCaptures": {
        "1": { "name": "punctuation.definition.string.feature" }
      },
      "contentName": "meta.embedded.block.json",
      "patterns": [{ "include": "source.json" }]
    },
    "docstringXml": {
      "begin": "^(\\s*)(\"\"\"|```)(xml)\\s*$",
      "end": "^\\1(\"\"\"|```)",
      "beginCaptures": {
        "2": { "name": "punctuation.definition.string.feature" },
        "3": { "name": "storage.type.docstring.feature" }
      },
      "endCaptures": {
        "1": { "name": "punctuation.definition.string.feature" }
      },
      "contentName": "meta.embedded.block.xml",
      "patterns": [{ "include": "text.xml" }]
    },
    "docstringHtml": {
      "begin": "^(\\s*)(\"\"\"|```)(html)\\s*$",
      "end": "^\\1(\"\"\"|```)",
      "beginCaptures": {
        "2": { "name": "punctuation.definition.string.feature" },
        "3": { "name": "storage.type.docstring.feature" }
      },
      "endCaptures": {
        "1": { "name": "punctuation.definition.string.feature" }
      },
      "contentName": "meta.embedded.block.html",
      "patterns": [{ "include": "text.html.basic" }]
    },
    "docstringJs": {
      "begin": "^(\\s*)(\"\"\"|```)(javascript|js)\\s*$",
      "end": "^\\1(\"\"\"|```)",
      "beginCaptures": {
        "2": { "name": "punctuation.definition.string.feature" },
        "3": { "name": "storage.type.docstring.feature" }
      },
      "endCaptures": {
        "1": { "name": "punctuation.definition.string.feature" }
      },
      "contentName": "meta.embedded.block.javascript",
      "patterns": [{ "include": "source.js" }]
    },
    "docstringTs": {
      "begin": "^(\\s*)(\"\"\"|```)(typescript|ts)\\s*$",
      "end": "^\\1(\"\"\"|```)",
      "beginCaptures": {
        "2": { "name": "punctuation.definition.string.feature" },
        "3": { "name": "storage.type.docstring.feature" }
      },
      "endCaptures": {
        "1": { "name": "punctuation.definition.string.feature" }
      },
      "contentName": "meta.embedded.block.typescript",
      "patterns": [{ "include": "source.ts" }]
    },
    "docstringSql": {
      "begin": "^(\\s*)(\"\"\"|```)(sql)\\s*$",
      "end": "^\\1(\"\"\"|```)",
      "beginCaptures": {
        "2": { "name": "punctuation.definition.string.feature" },
        "3": { "name": "storage.type.docstring.feature" }
      },
      "endCaptures": {
        "1": { "name": "punctuation.definition.string.feature" }
      },
      "contentName": "meta.embedded.block.sql",
      "patterns": [{ "include": "source.sql" }]
    },
    "docstringYaml": {
      "begin": "^(\\s*)(\"\"\"|```)(yaml|yml)\\s*$",
      "end": "^\\1(\"\"\"|```)",
      "beginCaptures": {
        "2": { "name": "punctuation.definition.string.feature" },
        "3": { "name": "storage.type.docstring.feature" }
      },
      "endCaptures": {
        "1": { "name": "punctuation.definition.string.feature" }
      },
      "contentName": "meta.embedded.block.yaml",
      "patterns": [{ "include": "source.yaml" }]
    },
    "docstringPython": {
      "begin": "^(\\s*)(\"\"\"|```)(python|py)\\s*$",
      "end": "^\\1(\"\"\"|```)",
      "beginCaptures": {
        "2": { "name": "punctuation.definition.string.feature" },
        "3": { "name": "storage.type.docstring.feature" }
      },
      "endCaptures": {
        "1": { "name": "punctuation.definition.string.feature" }
      },
      "contentName": "meta.embedded.block.python",
      "patterns": [{ "include": "source.python" }]
    },
    "docstring": {
      "begin": "^(\\s*)(\"\"\"|```)(\\w*)\\s*$",
      "end": "^\\1(\"\"\"|```)",
      "name": "string.quoted.docstring.feature",
      "beginCaptures": {
        "2": { "name": "punctuation.definition.string.feature" },
        "3": { "name": "storage.type.docstring.feature" }
      },
      "endCaptures": {
        "1": { "name": "punctuation.definition.string.feature" }
      }
    },
    "table": {
      "match": "^\\s*(\\|)(.+)(\\|)\\s*$",
      "captures": {
        "1": { "name": "punctuation.separator.table.feature" },
        "2": {
          "patterns": [
            { "include": "#tableCellSeparator" },
            { "include": "#stepPlaceholder" }
          ]
        },
        "3": { "name": "punctuation.separator.table.feature" }
      }
    },
    "tableCellSeparator": {
      "match": "\\|",
      "name": "punctuation.separator.table.feature"
    }
  }
}